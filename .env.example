# Copy this file to .env.local for local development.
# Keep real secrets out of git.

# Frontend public variables. These values are bundled into browser code.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_KAKAO_MAP_JS_KEY=
VITE_MAPBOX_TOKEN=
VITE_GOOGLE_MAPS_BROWSER_KEY=
VITE_GOOGLE_MAPS_API_KEY=

# Server-only TourAPI variables. Do not use the VITE_ prefix.
TOUR_API_BASE_URL=
TOUR_API_SERVICE_KEY=

# Server-only route/map proxy variables.
KAKAO_MOBILITY_REST_API_KEY=
KAKAO_REST_API_KEY=
GOOGLE_MAPS_SERVER_KEY=

# Server-only OpenAI variables.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=

# Server-only Supabase variables for admin dashboard and RAG APIs.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_KEY=

# Server-only admin variables.
ADMIN_ACCESS_CODE=
ADMIN_SESSION_SECRET=
