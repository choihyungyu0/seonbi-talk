# TourAPI service key is server-only. Do not use the VITE_ prefix.
# Do not place real keys in frontend code. Vercel should provide these as
# server environment variables for api/tourism.ts.
TOUR_API_BASE_URL=
TOUR_API_SERVICE_KEY=

# Kakao JavaScript map key for browser rendering. Do not commit real keys.
VITE_KAKAO_MAP_JS_KEY=
